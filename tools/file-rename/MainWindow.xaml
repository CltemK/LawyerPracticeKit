<Window x:Class="LegalFileRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="法律文件重命名"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- 标签 -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- 输入框 -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A5F"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 确认按钮 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E3A5F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A4F7A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#152D4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 取消按钮 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D5D5D5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0C0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 一键定稿按钮 -->
        <Style x:Key="FinalizeButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#F9A825"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F57F17"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E65100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 类型切换按钮（客户/律师） -->
        <Style x:Key="CategoryToggleButtonStyle" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A5F"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A5F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A5F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 子类型按钮 -->
        <Style x:Key="SubTypeToggleButtonStyle" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="Background" Value="#E8EEF5"/>
            <Setter Property="BorderBrush" Value="#C5D3E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A5F"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A5F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A5F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" Margin="20" Padding="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="2" Opacity="0.12" Color="#1E3A5F"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="法律文件重命名"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#1E3A5F"/>
                    <Border Background="#1E3A5F" Height="3" Width="40"
                            HorizontalAlignment="Left" CornerRadius="2"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 一键定稿提示栏 -->
            <Border x:Name="FinalizeBar"
                    Grid.Row="1"
                    Background="#FFF8E1"
                    CornerRadius="8"
                    Padding="14,10"
                    Margin="0,0,0,14"
                    BorderBrush="#FFD54F"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <TextBlock Text="检测到律师文件，可一键定稿"
                               FontFamily="Microsoft YaHei UI" FontSize="12"
                               Foreground="#F57F17" VerticalAlignment="Center"/>
                    <Button x:Name="FinalizeButton"
                            Content="一键定稿"
                            Style="{StaticResource FinalizeButtonStyle}"
                            Click="FinalizeButton_Click"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- 原文件路径 -->
            <StackPanel Grid.Row="2" Margin="0,0,0,14">
                <TextBlock Text="原文件" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="OriginalPathTextBox"
                         Style="{StaticResource InputTextBoxStyle}"
                         IsReadOnly="True"
                         Background="#F8F9FB"
                         Foreground="#888"/>
            </StackPanel>

            <!-- 日期 -->
            <StackPanel Grid.Row="3" Margin="0,0,0,14">
                <TextBlock Style="{StaticResource LabelStyle}">
                    <Run Text="日期"/>
                    <Run Text="  YYYYMMDD" Foreground="#AAA" FontSize="11"/>
                </TextBlock>
                <TextBox x:Name="DateTextBox"
                         Style="{StaticResource InputTextBoxStyle}"
                         MaxLength="8"/>
            </StackPanel>

            <!-- 文件类型：先选客户/律师 -->
            <StackPanel Grid.Row="4" Margin="0,0,0,14">
                <TextBlock Text="文件类型" Style="{StaticResource LabelStyle}"/>

                <!-- 一级分类 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="CategoryClientRadio"
                                 Content="客户文件"
                                 GroupName="Category"
                                 Style="{StaticResource CategoryToggleButtonStyle}"
                                 IsChecked="True"
                                 Checked="CategoryRadio_Checked"/>
                    <RadioButton x:Name="CategoryLawyerRadio"
                                 Content="律师文件"
                                 GroupName="Category"
                                 Style="{StaticResource CategoryToggleButtonStyle}"
                                 Margin="10,0,0,0"
                                 Checked="CategoryRadio_Checked"/>
                </StackPanel>

                <!-- 律师文件子选项 -->
                <StackPanel x:Name="LawyerSubTypePanel"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                    <RadioButton x:Name="SubTypeDraftRadio"
                                 Content="初稿"
                                 GroupName="SubType"
                                 Style="{StaticResource SubTypeToggleButtonStyle}"
                                 IsChecked="True"
                                 Checked="SubTypeRadio_Checked"/>
                    <RadioButton x:Name="SubTypeRevisionRadio"
                                 Content="修订"
                                 GroupName="SubType"
                                 Style="{StaticResource SubTypeToggleButtonStyle}"
                                 Margin="8,0,0,0"
                                 Checked="SubTypeRadio_Checked"/>
                    <RadioButton x:Name="SubTypeFinalRadio"
                                 Content="终稿"
                                 GroupName="SubType"
                                 Style="{StaticResource SubTypeToggleButtonStyle}"
                                 Margin="8,0,0,0"
                                 Checked="SubTypeRadio_Checked"/>
                </StackPanel>
            </StackPanel>

            <!-- 文件名称 -->
            <StackPanel Grid.Row="5" Margin="0,0,0,14">
                <TextBlock Text="文件名称" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="FileNameTextBox"
                         Style="{StaticResource InputTextBoxStyle}"/>
            </StackPanel>

            <!-- 版本号 -->
            <StackPanel Grid.Row="6" Margin="0,0,0,14">
                <TextBlock Style="{StaticResource LabelStyle}">
                    <Run Text="版本号"/>
                    <Run Text="  只需输入数字，如 1、1.1" Foreground="#AAA" FontSize="11"/>
                </TextBlock>
                <TextBox x:Name="VersionTextBox"
                         Style="{StaticResource InputTextBoxStyle}"
                         MaxLength="10"/>
            </StackPanel>

            <!-- 预览 -->
            <Border Grid.Row="7" Background="#F0F5FB" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="预览" FontFamily="Microsoft YaHei UI" FontSize="11"
                               Foreground="#7BA3C9" FontWeight="SemiBold"/>
                    <TextBlock x:Name="PreviewTextBlock"
                               FontFamily="Consolas"
                               FontSize="14"
                               Foreground="#1E3A5F"
                               FontWeight="Bold"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 错误 + 按钮 -->
            <Grid Grid.Row="8">
                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#D32F2F"
                           FontFamily="Microsoft YaHei UI"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="取消"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelButton_Click"
                            Margin="0,0,10,0"/>
                    <Button x:Name="ConfirmButton"
                            Content="确认重命名"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ConfirmButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
